# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit secrets
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ─── Dev/Debug Scripts (local use only) ──────────────────────────────────────
fetchIt.ts
fetchIt2.ts
fetchIt3.ts
check_db.mjs
check_schema.js

# ─── SQL Migrations / Data Scripts (use Supabase dashboard or migrations/) ──
*.sql

# ─── Logs & Reports (generated files, not source) ────────────────────────────
*.log
*.txt
eslint-report.json

# ─── Seeds output ─────────────────────────────────────────────────────────────
seed_output.log
output2.log
schema_info.txt
build-error*.txt
lint-error*.txt
